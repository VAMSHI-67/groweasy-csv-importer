# ===========================================
# GrowEasy CSV Importer — Environment Variables
# ===========================================
# Copy this file to .env and fill in values.

# --- AI Provider Configuration ---
# Which AI provider to use: "gemini" | "groq" | "openai" | "mock"
AI_PROVIDER=gemini

# Google Gemini API Key (free from https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Groq API Key (free from https://console.groq.com)
GROQ_API_KEY=

# OpenAI API Key (from https://platform.openai.com)
OPENAI_API_KEY=

# --- Server Configuration ---
API_PORT=3001
NODE_ENV=development

# --- Processing Configuration ---
# Number of CSV rows per AI batch (default: 20)
AI_BATCH_SIZE=20

# Max concurrent AI batch requests (default: 3)
AI_CONCURRENCY=3

# Max upload file size in bytes (default: 15MB)
MAX_FILE_SIZE=15728640

# Max rows per extraction request (default: 5000)
MAX_ROWS=5000

# --- Frontend Configuration ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Testing ---
# Set to "1" to run integration tests against live AI APIs
RUN_LIVE_AI_TESTS=0
